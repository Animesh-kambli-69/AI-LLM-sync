{
  "schema_version": "1.1",
  "description": "Conductor AI Intelligence System - Shared data store for all local AI agents",
  "paths": {
    "memory": "intelligence/memory",
    "sessions": "intelligence/sessions",
    "lessons": "intelligence/lessons",
    "outputs": "intelligence/outputs",
    "context": "intelligence/context"
  },
  "memory": {
    "max_snippets": 1000,
    "embedding_model": "nomic-embed-text:v1.5"
  },
  "model_wiring": {
    "planner": [
      "llama3.1:8b"
    ],
    "worker": "qwen2.5-coder:7b",
    "critic": "mistral:7b",
    "synthesizer": "mistral:7b"
  },
  "inference": {
    "cpu_optimizations": {
      "enabled": true,
      "max_parallel_requests": 3,
      "response_streaming": true,
      "aggressive_unload": false,
      "model_keep_alive_ms": 120000,
      "max_cached_models": 4,
      "enable_memory_monitoring": true,
      "auto_reduce_parallel": true,
      "vram_threshold_percent": 85,
      "temperature": 0.1
    }
  },
  "sandbox": {
    "description": "STRICT allowlist. Agents can ONLY read/write paths listed here. Add your workspace folders here.",
    "allowed_paths": [
      "C:/Users/Ani/OneDrive/Desktop/codes/Pure Shit",
      "C:/Users/Ani/OneDrive/Desktop/codes/AI LLM sync"
    ],
    "allow_reads_outside_sandbox": false
  },
  "approval": {
    "description": "Controls when the system must pause and ask you before proceeding.",
    "require_approval_for": {
      "file_write": false,
      "file_overwrite": false,
      "file_delete": true,
      "plan_change": false,
      "critic_loop_retry": false,
      "memory_write": false
    }
  }
}
